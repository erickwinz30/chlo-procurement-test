        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login and get bearer token",
                "operationId": "a4fe6a4c59acf801bd0b5cf181b98ccd",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "employee@test.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login success"
                    },
                    "422": {
                        "description": "Validation or credential error"
                    }
                }
            }
        },
